<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>予約管理画面</title>
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Hiragino Sans", "Yu Gothic", "YuGothic", sans-serif;
      background: #f6f4ef;
      color: #222;
    }

    .layout {
      display: grid;
      grid-template-columns: 240px 1fr;
      min-height: 100vh;
    }

    .sidebar {
      background: #1f1f1f;
      color: #fff;
      padding: 24px 18px;
    }

    .logo {
      font-size: 22px;
      font-weight: 800;
      margin-bottom: 28px;
    }

    .nav a {
      display: block;
      color: #ddd;
      text-decoration: none;
      padding: 13px 14px;
      border-radius: 12px;
      margin-bottom: 6px;
      font-size: 14px;
    }

    .nav a.active,
    .nav a:hover {
      background: #333;
      color: #fff;
    }

    .main {
      padding: 28px;
    }

    .top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      margin-bottom: 24px;
    }

    h1 {
      margin: 0;
      font-size: 28px;
    }

    .add-btn {
      background: #222;
      color: #fff;
      border: none;
      padding: 13px 18px;
      border-radius: 14px;
      font-weight: 700;
      cursor: pointer;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
      margin-bottom: 22px;
    }

    .stat-card {
      background: #fff;
      border-radius: 18px;
      padding: 18px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.05);
    }

    .stat-label {
      font-size: 13px;
      color: #777;
    }

    .stat-number {
      font-size: 28px;
      font-weight: 800;
      margin-top: 8px;
    }

    .content-grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      gap: 18px;
    }

    .panel {
      background: #fff;
      border-radius: 22px;
      padding: 20px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.05);
    }

    .panel h2 {
      margin: 0 0 16px;
      font-size: 18px;
    }

    .reservation {
      display: grid;
      grid-template-columns: 80px 1fr auto;
      gap: 14px;
      align-items: center;
      border-bottom: 1px solid #eee;
      padding: 14px 0;
    }

    .reservation:last-child {
      border-bottom: none;
    }

    .time {
      font-weight: 800;
      font-size: 15px;
    }

    .name {
      font-weight: 700;
      margin-bottom: 4px;
    }

    .detail {
      font-size: 13px;
      color: #777;
    }

    .status {
      font-size: 12px;
      font-weight: 700;
      padding: 7px 10px;
      border-radius: 999px;
      background: #f0eadf;
    }

    .status.confirmed {
      background: #e8f5ed;
      color: #217a43;
    }

    .status.block {
      background: #f2f2f2;
      color: #777;
    }

    .form-row {
      margin-bottom: 12px;
    }

    label {
      display: block;
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 6px;
    }

    input,
    select,
    textarea {
      width: 100%;
      padding: 12px 13px;
      border: 1px solid #ddd7ce;
      border-radius: 13px;
      font-size: 14px;
    }

    textarea {
      min-height: 82px;
    }

    .save-btn {
      width: 100%;
      background: #222;
      color: #fff;
      border: none;
      border-radius: 14px;
      padding: 14px;
      font-weight: 700;
      cursor: pointer;
      margin-top: 8px;
    }

    @media (max-width: 800px) {
      .layout {
        grid-template-columns: 1fr;
      }

      .sidebar {
        position: static;
      }

      .stats,
      .content-grid {
        grid-template-columns: 1fr;
      }

      .top {
        align-items: flex-start;
        flex-direction: column;
      }
    }
  </style>
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <div class="logo">ととのい+ 管理</div>
      <nav class="nav">
        <a href="#" class="active">予約一覧</a>
        <a href="#">カレンダー</a>
        <a href="#">予約追加</a>
        <a href="#">ブロック設定</a>
        <a href="#">顧客管理</a>
        <a href="reservation.html">予約ページを開く</a>
      </nav>
    </aside>

    <main class="main">
      <div class="top">
        <div>
          <h1>予約管理</h1>
          <p>今日の予約・手動追加・ブロックをまとめて管理します。</p>
        </div>
        <button class="add-btn">＋ 予約を追加</button>
      </div>

      <section class="stats">
        <div class="stat-card">
          <div class="stat-label">今日の予約</div>
          <div class="stat-number">6</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">明日の予約</div>
          <div class="stat-number">4</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">未確認</div>
          <div class="stat-number">2</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">ブロック</div>
          <div class="stat-number">1</div>
        </div>
      </section>

      <section class="content-grid">
        <div class="panel">
          <h2>2026/06/14 今日の予約</h2>

          <div class="reservation">
            <div class="time">10:00</div>
            <div>
              <div class="name">山田 様</div>
              <div class="detail">プライベートサウナ90分 / ROOM1 / 2名</div>
            </div>
            <div class="status confirmed">予約確定</div>
          </div>

          <div class="reservation">
            <div class="time">11:30</div>
            <div>
              <div class="name">佐藤 様</div>
              <div class="detail">ギフトチケット利用 / ROOM2 / 1名</div>
            </div>
            <div class="status confirmed">予約確定</div>
          </div>

          <div class="reservation">
            <div class="time">13:00</div>
            <div>
              <div class="name">清掃</div>
              <div class="detail">ROOM1 清掃・メンテナンス</div>
            </div>
            <div class="status block">ブロック</div>
          </div>

          <div class="reservation">
            <div class="time">14:30</div>
            <div>
              <div class="name">田中 様</div>
              <div class="detail">会議室利用 / 4名</div>
            </div>
            <div class="status confirmed">予約確定</div>
          </div>
        </div>

        <div class="panel">
          <h2>手動予約追加</h2>

          <div class="form-row">
            <label>お名前</label>
            <input type="text" placeholder="例：山田 太郎">
          </div>

          <div class="form-row">
            <label>メニュー</label>
            <select>
              <option>プライベートサウナ 90分</option>
              <option>プライベートサウナ 120分</option>
              <option>コワーキング利用</option>
              <option>会議室利用</option>
              <option>ギフトチケット利用</option>
            </select>
          </div>

          <div class="form-row">
            <label>予約日</label>
            <input type="date">
          </div>

          <div class="form-row">
            <label>開始時間</label>
            <input type="time">
          </div>

          <div class="form-row">
            <label>部屋</label>
            <select>
              <option>ROOM1</option>
              <option>ROOM2</option>
              <option>ROOM3</option>
              <option>ROOM4</option>
              <option>ROOM5</option>
              <option>コワーキング</option>
              <option>会議室</option>
            </select>
          </div>

          <div class="form-row">
            <label>メモ</label>
            <textarea placeholder="電話予約・LINE予約・ギフト券利用など"></textarea>
          </div>

          <button class="save-btn" onclick="alert('次のステップでスプレッドシート保存に対応します')">
            予約を保存
          </button>
        </div>
      </section>
    </main>
  </div>
</body>
</html>
